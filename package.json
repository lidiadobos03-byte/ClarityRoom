{
  "name": "clarityroom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --env-file-if-exists=.env server/index.js",
    "dev:web": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node --env-file-if-exists=.env server/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^18.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "vite": "^7.0.0"
  }
}
